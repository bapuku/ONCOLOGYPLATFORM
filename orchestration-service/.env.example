# OncoAgent Orchestration Service - Environment Variables
# Copy to .env and fill in values

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=oncoagent_dev

# Weaviate Vector Store
WEAVIATE_URL=http://localhost:8081

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM Providers (set at least one for live inference)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# On-premise Granite endpoint
GRANITE_ENDPOINT=http://localhost:8001/v1/chat/completions

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
